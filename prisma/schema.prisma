generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HubContact {
  id                  String           @id @default(cuid())
  name                String           @unique
  emoji               String           @default("👤")
  country             String?          // e.g. "Chine", "Tunisie", "France"
  isArchived          Boolean          @default(false)
  heldBalanceUsd      Float            @default(0)    // Avoirs (Aggregated USD)
  receivableBalanceUsd Float           @default(0)    // Créances (Aggregated USD)
  payableBalanceUsd    Float            @default(0)    // Dettes (Aggregated USD)
  netPositionUsd      Float            @default(0)    // held + receivable - payable
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  transactions        HubTransaction[] @relation("ContactTransactions")
  reminders           HubReminder[]    @relation("ContactReminders")
}

model HubCurrency {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "USD", "EUR", "CNY", "TND", "HKD"
  symbol    String   // e.g. "$", "€", "¥", "DT", "HK$"
  rateToUsd Float    // conversion rate (e.g. 1 EUR = 1.08 USD, 1 TND = 0.32 USD)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HubCategory {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "Virement", "Prêt", "Dépôt", "Investissement"
  isCustom  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HubTransaction {
  id             String           @id @default(cuid())
  amount         Float            // Original amount
  currencyCode   String           @default("USD")
  amountInUsd    Float            // Converted amount in USD
  contactId      String
  contact        HubContact       @relation("ContactTransactions", fields: [contactId], references: [id], onDelete: Cascade)
  type           String           // "HELD" (Avoirs), "RECEIVABLE" (Créance), "PAYABLE" (Dette)
  category       String           // "Virement", "Prêt", etc.
  note           String?
  photoPath      String?          // Attachment filepath/URL
  attachmentName String?          // Name of the uploaded file
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  audits         HubAuditTrail[]  @relation("TransactionAudits")
}

model HubReminder {
  id           String     @id @default(cuid())
  amount       Float
  currencyCode String     @default("USD")
  amountInUsd  Float
  contactId    String
  contact      HubContact @relation("ContactReminders", fields: [contactId], references: [id], onDelete: Cascade)
  dueDate      DateTime
  note         String?
  isCompleted  Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model HubAuditTrail {
  id            String          @id @default(cuid())
  transactionId String?
  transaction   HubTransaction? @relation("TransactionAudits", fields: [transactionId], references: [id], onDelete: SetNull)
  fieldName     String          // "amount", "note", "delete", "create", "edit"
  oldValue      String?
  newValue      String?
  modifiedBy    String          @default("Administrateur")
  createdAt     DateTime        @default(now())
}

model HubUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   // MD5 or plain text or SHA-256 (simple string compare for private app)
  role         String   @default("assistant") // "admin" | "assistant"
  canWrite     Boolean  @default(true)
  canEdit      Boolean  @default(false)
  canDelete    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
