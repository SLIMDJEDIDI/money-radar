generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MoneyHolder {
  id              String          @id @default(cuid())
  name            String          @unique
  emoji           String          @default("💵")
  color           String          @default("blue")    // "green" (owed to you), "blue" (your own), "orange" (inventory), "red" (you owe)
  category        String          @default("holder")  // "holder" (your own cash/banks), "partner" (3rd parties), "upcoming" (debit accounts / upcoming payments)
  partnerType     String?         // "person" | "company" (if category == "partner")
  isUpcoming      Boolean         @default(false)     // true if category == "upcoming"
  expectedBalance Float           @default(0)         // Aggregated USD value
  actualBalance   Float           @default(0)         // Aggregated USD value
  isSpecialTransit Boolean        @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  balances        HolderBalance[]
  movementsFrom   MoneyMovement[] @relation("FromHolder")
  movementsTo     MoneyMovement[] @relation("ToHolder")
}

model HolderBalance {
  id              String      @id @default(cuid())
  holderId        String
  holder          MoneyHolder @relation(fields: [holderId], references: [id], onDelete: Cascade)
  currency        String      @default("USD")     // "USD" | "EUR" | "TND"
  expectedBalance Float       @default(0)
  actualBalance   Float       @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([holderId, currency])
}

model MoneyMovement {
  id           String       @id @default(cuid())
  amount       Float        // Original amount
  currency     String       @default("USD")     // "USD" | "EUR" | "TND"
  amountInUsd  Float        // Converted amount in USD
  fromHolderId String?
  fromHolder   MoneyHolder? @relation("FromHolder", fields: [fromHolderId], references: [id], onDelete: SetNull)
  toHolderId   String?
  toHolder     MoneyHolder? @relation("ToHolder", fields: [toHolderId], references: [id], onDelete: SetNull)
  note         String?
  photoPath    String?      // Local filepath of proof (e.g. "/uploads/proof_xyz.jpg")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
