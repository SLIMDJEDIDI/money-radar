generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HubContact {
  id                  String           @id @default(cuid())
  name                String           @unique
  emoji               String           @default("👤")
  country             String?
  isArchived          Boolean          @default(false)
  heldBalanceUsd      Float            @default(0)
  receivableBalanceUsd Float           @default(0)
  payableBalanceUsd    Float            @default(0)
  netPositionUsd      Float            @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  transactions        HubTransaction[] @relation("ContactTransactions")
  reminders           HubReminder[]    @relation("ContactReminders")

  @@index([name])
  @@index([isArchived])
}

model HubCurrency {
  id        String   @id @default(cuid())
  code      String   @unique
  symbol    String
  rateToUsd Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HubCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  isCustom  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HubTransaction {
  id             String           @id @default(cuid())
  amount         Float
  currencyCode   String           @default("USD")
  amountInUsd    Float
  contactId      String
  contact        HubContact       @relation("ContactTransactions", fields: [contactId], references: [id], onDelete: Cascade)
  type           String           // "HELD", "RECEIVABLE", "PAYABLE"
  category       String
  note           String?
  photoPath      String?
  attachmentName String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([contactId])
  @@index([type])
  @@index([createdAt])
}

model HubReminder {
  id            String     @id @default(cuid())
  amount        Float
  currencyCode  String     @default("USD")
  amountInUsd   Float
  contactId     String
  contact       HubContact @relation("ContactReminders", fields: [contactId], references: [id], onDelete: Cascade)
  dueDate       DateTime
  note          String?
  reminderEmail String?
  lastNotifiedAt DateTime?
  isCompleted    Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([contactId])
  @@index([dueDate])
  @@index([isCompleted])
}

model HubAuditTrail {
  id            String   @id @default(cuid())
  entityType    String   // "TRANSACTION", "CONTACT", "REMINDER", "SETTING", "USER"
  entityId      String?
  action        String   // "CREATE", "UPDATE", "DELETE", "WIPE", "LOGIN"
  details       String?  // Description textuelle riche
  oldValue      String?  // Valeur avant modif (JSON ou texte)
  newValue      String?  // Valeur après modif (JSON ou texte)
  modifiedBy    String   // Nom de l'utilisateur
  createdAt     DateTime @default(now())

  @@index([entityType])
  @@index([createdAt])
  @@index([modifiedBy])
}

model HubUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("assistant")
  canWrite     Boolean  @default(true)
  canEdit      Boolean  @default(false)
  canDelete    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
